# Serveur
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=votre_secret_jwt_tres_securise_ici
JWT_EXPIRES_IN=8h

# Base de données (SQLite - chemin du fichier)
DB_PATH=./database.sqlite

# Email (SMTP - ex: Gmail, SendGrid)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre_email@gmail.com
EMAIL_PASS=votre_mot_de_passe_app
EMAIL_FROM=VTC 3M <noreply@vtc3m.fr>

# Email administrateur/chauffeur (destinataire des notifications)
ADMIN_EMAIL=chauffeur@vtc3m.fr

# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=votre_auth_token_twilio
TWILIO_FROM_NUMBER=+33xxxxxxxxx
ADMIN_PHONE=+33xxxxxxxxx

# URL Frontend (pour CORS)
FRONTEND_URL=http://localhost:3000

# Entreprise (utilisé dans les PDFs)
COMPANY_NAME=VTC 3M
COMPANY_ADDRESS=123 Avenue des Champs, 75008 Paris
COMPANY_PHONE=+33 6 XX XX XX XX
COMPANY_EMAIL=contact@vtc3m.fr
COMPANY_SIRET=XXX XXX XXX XXXXX
