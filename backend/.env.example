# ═══════════════════════════════════════════════════════════════
#  3M Drive — Variables d'environnement
#  Copier ce fichier en .env et remplir chaque valeur.
#  ⚠  NE JAMAIS COMMITER LE FICHIER .env SUR GIT ⚠
# ═══════════════════════════════════════════════════════════════

# ── Serveur ───────────────────────────────────────────────────
PORT=5001
# IMPORTANT : mettre "production" lors du déploiement
NODE_ENV=development
# Nombre de "hops" de proxy de confiance pour req.ip (voir index.js).
# Par défaut : 1 en production, 0 en dev. À ajuster seulement si un proxy
# supplémentaire (CDN, load balancer) se trouve devant le reverse proxy.
# TRUST_PROXY_HOPS=1

# ── JWT ───────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimum 64 caractères, totalement aléatoire
JWT_SECRET=REMPLACER_PAR_UN_SECRET_ALEATOIRE_64_CHARS_MINIMUM
JWT_EXPIRES_IN=8h

# ── Base de données ───────────────────────────────────────────
# SQLite (développement / démo locale uniquement)
DB_PATH=./database.sqlite

# PostgreSQL (PRODUCTION — remplace SQLite si défini)
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Exemples d'hébergeurs : Railway, Render, Supabase, Neon, Heroku Postgres
# DATABASE_URL=postgresql://user:password@host:5432/vtc3m
# DB_SSL=true   # Mettre true pour Render, Railway, Heroku (SSL requis)

# ── Email SMTP ────────────────────────────────────────────────
# Gmail : créer un "Mot de passe d'application" sur myaccount.google.com
# (NE PAS utiliser le mot de passe principal du compte Google)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre_email@gmail.com
EMAIL_PASS=VOTRE_MOT_DE_PASSE_APPLICATION_GMAIL
EMAIL_FROM=3M Services <noreply@votre-domaine.fr>

# Email de réception des notifications admin/chauffeur
ADMIN_EMAIL=votre_email@gmail.com

# Coupe-circuit — passer à false pour désactiver l'envoi réel (tests)
EMAIL_ENABLED=true

# ── Compte chauffeur par défaut (seed) ───────────────────────
# Changer IMPÉRATIVEMENT avant déploiement
ADMIN_NAME=Votre Nom
ADMIN_LOGIN_EMAIL=chauffeur@votre-domaine.fr
ADMIN_PASSWORD=MotDePasseForte1234!

# ── Twilio SMS (optionnel) ────────────────────────────────────
# Coupe-circuit — passer à false pour désactiver l'envoi réel (tests)
SMS_ENABLED=true
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=votre_auth_token_twilio
TWILIO_FROM_NUMBER=+33XXXXXXXXX
ADMIN_PHONE=+33XXXXXXXXX

# ── URLs (adapter au domaine de production) ──────────────────
# En production : https://votredomaine.fr (sans slash final)
# Plusieurs origines séparées par virgule : https://a.fr,https://b.fr
FRONTEND_URL=http://localhost:3000

# ── Entreprise (utilisé dans les PDFs et emails) ─────────────
COMPANY_NAME=3M Services 31
COMPANY_ADDRESS=Toulouse, Haute-Garonne (31), France
COMPANY_PHONE=+33XXXXXXXXX
COMPANY_EMAIL=contact@votre-domaine.fr
COMPANY_SIRET=XXX XXX XXX XXXXX
# Année de création — repli pour l'affichage "X années d'activité" si aucune
# réservation n'existe encore en base. Optionnel.
# COMPANY_START_YEAR=2024

# ── Tarification (valeurs d'amorçage — 1er démarrage sur base vide) ─────
# Ne servent qu'à créer la ligne PricingConfig initiale contre une base neuve ;
# la tarification réelle est ensuite gérée depuis l'interface admin.
# Repli code si absentes : PRICE_PER_KM=2.0 / MINIMUM_PRICE=10.0 / BASE_FEE=0.0
# PRICE_PER_KM=2.0
# MINIMUM_PRICE=10.0
# BASE_FEE=0.0

# ── Stripe (abonnements — optionnel si non utilisé) ──────────
# Clés disponibles sur https://dashboard.stripe.com/apikeys
# Utiliser les clés sk_test_* en dev, sk_live_* en production
STRIPE_SECRET_KEY=sk_test_REMPLACER_PAR_VOTRE_CLE
STRIPE_WEBHOOK_SECRET=whsec_REMPLACER_PAR_VOTRE_SECRET_WEBHOOK
STRIPE_PRICE_ID_MONTHLY=price_REMPLACER_PAR_ID_MENSUEL
STRIPE_PRICE_ID_YEARLY=price_REMPLACER_PAR_ID_ANNUEL
